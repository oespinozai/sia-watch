{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "Editorial precision identity for Alvento, the umbrella brand for narrow intelligence products, with SIA Watch as the first live product.",
  "color": {
    "$type": "color",
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.357,
          0.361,
          0.941
        ],
        "hex": "#5b5cf0"
      }
    },
    "primary-hover": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.31,
          0.275,
          0.898
        ],
        "hex": "#4f46e5"
      }
    },
    "secondary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.125,
          0.592,
          0.043
        ],
        "hex": "#20970b"
      }
    },
    "neutral": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.541,
          0.541,
          0.588
        ],
        "hex": "#8a8a96"
      }
    },
    "background": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.98,
          0.98,
          0.98
        ],
        "hex": "#fafafa"
      }
    },
    "surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          1,
          1
        ],
        "hex": "#ffffff"
      }
    },
    "surface-alt": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.961,
          0.961,
          0.973
        ],
        "hex": "#f5f5f8"
      }
    },
    "surface-accent": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.953,
          0.953,
          1
        ],
        "hex": "#f3f3ff"
      }
    },
    "text-primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.039,
          0.039,
          0.039
        ],
        "hex": "#0a0a0a"
      }
    },
    "text-secondary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.38,
          0.38,
          0.427
        ],
        "hex": "#61616d"
      }
    },
    "border": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.91,
          0.91,
          0.925
        ],
        "hex": "#e8e8ec"
      }
    },
    "success": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.063,
          0.725,
          0.506
        ],
        "hex": "#10b981"
      }
    },
    "warning": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.961,
          0.62,
          0.043
        ],
        "hex": "#f59e0b"
      }
    },
    "error": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.937,
          0.267,
          0.267
        ],
        "hex": "#ef4444"
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "xs": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 12,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 24,
        "unit": "px"
      }
    },
    "xxl": {
      "$value": {
        "value": 32,
        "unit": "px"
      }
    },
    "xxxl": {
      "$value": {
        "value": 48,
        "unit": "px"
      }
    }
  },
  "rounded": {
    "$type": "dimension",
    "sm": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 12,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    }
  },
  "typography": {
    "h1": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 4.25,
          "unit": "rem"
        },
        "fontWeight": 800,
        "letterSpacing": {
          "value": -0.05,
          "unit": "em"
        }
      }
    },
    "h2": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 2.25,
          "unit": "rem"
        },
        "fontWeight": 750,
        "letterSpacing": {
          "value": -0.04,
          "unit": "em"
        }
      }
    },
    "body-md": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 1,
          "unit": "rem"
        },
        "fontWeight": 400
      }
    },
    "body-lg": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 1.14,
          "unit": "rem"
        },
        "fontWeight": 400
      }
    },
    "label-sm": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 0.82,
          "unit": "rem"
        },
        "fontWeight": 700,
        "letterSpacing": {
          "value": 0.02,
          "unit": "em"
        }
      }
    }
  }
}
